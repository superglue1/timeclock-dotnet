@page "/admin/pto-requests"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Manager,Supervisor")]
@inject ApplicationDbContext Db
@inject PtoService PtoSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthProvider
@using Microsoft.EntityFrameworkCore

<PageTitle>PTO Requests</PageTitle>

<h1>PTO Requests</h1>

<div class="mb-3">
    <InputSelect @bind-Value="_statusFilter" class="form-select d-inline-block w-auto">
        <option value="0">Pending</option>
        <option value="1">Approved</option>
        <option value="2">Denied</option>
        <option value="-1">All</option>
    </InputSelect>
    <button class="btn btn-secondary ms-2" @onclick="Load">Refresh</button>
</div>

@if (_requests == null)
{
    <p>Loading...</p>
}
else if (_requests.Count == 0)
{
    <p class="text-muted">No requests.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Start</th>
                <th>End</th>
                <th>Hours</th>
                <th>Status</th>
                <th>Reason</th>
                <th>Balance</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _requests)
            {
                <tr>
                    <td>@r.User?.FullName</td>
                    <td>@r.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@r.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>@r.HoursRequested.ToString("F2")</td>
                    <td><span class="badge @StatusClass(r.Status)">@r.Status</span></td>
                    <td>@r.Reason</td>
                    <td>@(r.User?.PtoBalanceHours.ToString("F2"))</td>
                    <td>
                        @if (r.Status == PtoRequestStatus.Pending)
                        {
                            <button class="btn btn-sm btn-success me-1" @onclick="() => Approve(r.Id)">Approve</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Deny(r.Id)">Deny</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_ok ? "alert-success" : "alert-danger") mt-3">@_message</div>
}

@code {
    private int _statusFilter = 0;
    private List<PtoRequest>? _requests;
    private string? _message;
    private bool _ok;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var q = Db.PtoRequests.Include(r => r.User).AsQueryable();
        if (_statusFilter >= 0)
        {
            var s = (PtoRequestStatus)_statusFilter;
            q = q.Where(r => r.Status == s);
        }
        _requests = await q.OrderByDescending(r => r.CreatedAt).Take(200).ToListAsync();
    }

    private async Task Approve(int id)
    {
        _message = null;
        try
        {
            var state = await AuthProvider.GetAuthenticationStateAsync();
            var me = await UserManager.GetUserAsync(state.User);
            await PtoSvc.ApproveAsync(id, me!.Id);
            _ok = true; _message = "Approved.";
            await Load();
        }
        catch (Exception ex) { _ok = false; _message = ex.Message; }
    }

    private async Task Deny(int id)
    {
        _message = null;
        try
        {
            var state = await AuthProvider.GetAuthenticationStateAsync();
            var me = await UserManager.GetUserAsync(state.User);
            await PtoSvc.DenyAsync(id, me!.Id);
            _ok = true; _message = "Denied.";
            await Load();
        }
        catch (Exception ex) { _ok = false; _message = ex.Message; }
    }

    private static string StatusClass(PtoRequestStatus s) => s switch
    {
        PtoRequestStatus.Approved => "bg-success",
        PtoRequestStatus.Denied => "bg-danger",
        PtoRequestStatus.Cancelled => "bg-secondary",
        _ => "bg-warning text-dark"
    };
}
