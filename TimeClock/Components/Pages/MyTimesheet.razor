@page "/my-timesheet"
@rendermode InteractiveServer
@attribute [Authorize]
@inject TimeClockService ClockSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthProvider

<PageTitle>My Timesheet</PageTitle>

<h1>My Timesheet</h1>

<div class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label>From</label>
        <InputDate @bind-Value="_from" class="form-control" />
    </div>
    <div class="col-auto">
        <label>To</label>
        <InputDate @bind-Value="_to" class="form-control" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="Load">Reload</button>
    </div>
</div>

@if (_entries == null)
{
    <p>Loading...</p>
}
else if (_entries.Count == 0)
{
    <p class="text-muted">No entries in this range.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Clock In</th>
                <th>Clock Out</th>
                <th>Hours</th>
                <th>Type</th>
                <th>Pay Code</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in _entries)
            {
                <tr>
                    <td>@e.ClockInUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(e.ClockOutUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "— open —")</td>
                    <td>@((e.TotalHours ?? e.CalculateHours()).ToString("F2"))</td>
                    <td>@e.EntryType</td>
                    <td>@e.PayCode</td>
                    <td><small class="text-muted">@e.ClockInIpAddress</small></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="2">Total</th>
                <th>@_entries.Where(e => e.ClockOutUtc != null).Sum(e => e.TotalHours ?? e.CalculateHours()).ToString("F2")</th>
                <th colspan="3"></th>
            </tr>
        </tfoot>
    </table>
}

@code {
    private DateTime _from = DateTime.Today.AddDays(-14);
    private DateTime _to = DateTime.Today.AddDays(1);
    private List<TimeEntry>? _entries;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(state.User);
        if (user == null) return;
        _entries = await ClockSvc.GetEntriesForUserAsync(user.Id, _from.ToUniversalTime(), _to.ToUniversalTime());
    }
}
